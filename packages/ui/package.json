{
  "name": "@repasse-seguro/ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "typecheck": "tsc --noEmit"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles.css": "./src/styles.css",
    "./theme-provider": {
      "types": "./src/theme-provider.tsx",
      "import": "./src/theme-provider.tsx"
    },
    "./components/*": {
      "types": "./src/components/*",
      "import": "./src/components/*"
    },
    "./hooks/use-mobile": {
      "types": "./src/hooks/use-mobile.ts",
      "import": "./src/hooks/use-mobile.ts"
    },
    "./hooks/*": {
      "types": "./src/hooks/*",
      "import": "./src/hooks/*"
    },
    "./lib/utils": {
      "types": "./src/lib/utils.ts",
      "import": "./src/lib/utils.ts"
    },
    "./lib/*": {
      "types": "./src/lib/*",
      "import": "./src/lib/*"
    },
    "./components/ui/*": {
      "types": "./src/components/ui/*.tsx",
      "import": "./src/components/ui/*.tsx"
    }
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/inter": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "^4.7.6",
    "recharts": "^3.8.0",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  }
}
