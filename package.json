{
  "name": "repasse-seguro-v3",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@repasse-seguro/web",
    "build": "turbo build",
    "build:web": "turbo build --filter=@repasse-seguro/web",
    "lint": "turbo lint",
    "lint:web": "turbo lint --filter=@repasse-seguro/web",
    "format": "turbo format",
    "format:web": "turbo format --filter=@repasse-seguro/web",
    "typecheck": "turbo typecheck",
    "typecheck:web": "turbo typecheck --filter=@repasse-seguro/web",
    "preview:web": "npm run preview --workspace @repasse-seguro/web",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:link": "supabase link"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.5.8",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
